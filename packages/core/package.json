{
  "name": "@bigpuddle/dot-engine-core",
  "version": "0.2.2",
  "description": "Pure TypeScript DAG authoring API for 3D dot-field rendering — SDFs, displacement, animation, color",
  "license": "MIT",
  "author": "bigpuddle",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigpuddle/dot-engine"
  },
  "keywords": [
    "3d",
    "dots",
    "sdf",
    "branding",
    "generative",
    "webgl",
    "three"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  }
}
