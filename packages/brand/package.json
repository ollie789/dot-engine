{
  "name": "@bigpuddle/dot-engine-brand",
  "version": "0.2.3",
  "description": "Brand identity layer for dot-engine — defineBrand, logo import, personality, contexts, particles",
  "license": "MIT",
  "author": "bigpuddle",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigpuddle/dot-engine"
  },
  "keywords": [
    "branding",
    "logo",
    "identity",
    "3d",
    "dots",
    "generative"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
