{
  "name": "@bigpuddle/dot-engine-export",
  "version": "0.1.0",
  "description": "Export utilities for dot-engine — SVG and PNG rendering from dot fields",
  "license": "MIT",
  "author": "bigpuddle",
  "repository": { "type": "git", "url": "https://github.com/bigpuddle/dot-engine" },
  "keywords": ["3d", "dots", "svg", "png", "export", "generative"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bigpuddle/dot-engine-core": "workspace:*",
    "@bigpuddle/dot-engine-renderer": "workspace:*"
  },
  "peerDependencies": {
    "three": "^0.175.0"
  },
  "devDependencies": {
    "three": "^0.175.0",
    "@types/three": "^0.175.0"
  }
}
